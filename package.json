    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "vite": "^5.0.8"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}