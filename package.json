{
  "name": "bcm4331-fedora-deterministic-network-controller",
  "private": true,
  "version": "39.8.0",
  "type": "module",
  "scripts": {
    "dev": "PROJECT_ROOT=$(pwd) tsx server.ts",
    "setup": "chmod +x *.sh && PROJECT_ROOT=$(pwd) ./setup-system.sh",
    "cold-start": "PROJECT_ROOT=$(pwd) bash cold-start.sh",
